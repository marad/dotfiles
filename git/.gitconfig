[user]
    name = Marcin Radoszewski
    # email comes from ~/.gitconfig.local

[include]
    path = ~/.gitconfig.local

[alias]
    graph = log --graph --abbrev-commit --decorate --date=relative --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(bold yellow)%d%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
    tree = !"git graph"
    st = status
    ci = commit
    co = checkout
    br = branch
    aa = add --all
    di = diff
    dc = diff --cached

[color]
    ui = true
    status = auto
    branch = auto
    interactive = auto
    diff = auto

[push]
    default = simple
    autoSetupRemote = true

[core]
    editor = nvim
    autocrlf = input
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3

[branch]
    autosetuprebase = always

[init]
    defaultBranch = main

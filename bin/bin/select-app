#!/bin/env bash

options="File Manager
Calculator
Run an App
Audio Output
Reboot
Shutdown"

if [[ "$XDG_SESSION_TYPE" == "wayland" ]]; then
    selected=$(echo -e "$options" | fuzzel --dmenu -p "Select app: ")
else
    selected=$(echo -e "$options" | rofi -dmenu -i -p "Select app:")
fi

case "$selected" in
    "File Manager")
        nemo &
        ;;
    "Calculator")
        gnome-calculator &
        ;;
    "Run an App")
        if [[ "$XDG_SESSION_TYPE" == "wayland" ]]; then
            fuzzel &
        else
            rofi -show drun &
        fi
        ;;
    "Audio Output")
        select-audio-out &
        ;;
    "Reboot")
        systemctl reboot
        ;;
    "Shutdown")
        systemctl poweroff
        ;;
    *)
        exit 1
        ;;
esac

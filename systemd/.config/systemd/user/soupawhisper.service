[Unit]
Description=SoupaWhisper Voice Dictation
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=%h/dev/soupawhisper
ExecStart=%h/.local/bin/poetry run python dictate.py
Restart=on-failure
RestartSec=5

# X11 display access
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority

[Install]
WantedBy=default.target
